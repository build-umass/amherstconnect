# Copy this file to .env and fill in values received
# DO NOT commit the .env file — it is in .gitignore

# Firebase
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Google OAuth — from GCP → APIs & Services → Credentials.
# - Web client ID is required (Firebase validates the ID token audience against it).
# - iOS / Android client IDs are used on-device by expo-auth-session.
#   Set the one matching the platform you're testing on; the other can be blank.
# The "Continue with Google" button is hidden at runtime when GOOGLE_WEB_CLIENT_ID
# is not set.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
